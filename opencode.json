  "command": {
    "check": {
      "description": "Run the repository verification targets",
      "agent": "build",
      "template": "Run the available non-destructive verification targets for this Python project. Prefer make compile, make format-check, make lint, make typecheck, and make test when they exist. Do not modify files. Summarize failures with exact files, commands, and minimal suggested fixes."
    },
    "review": {
      "description": "Review the current working tree changes",
      "agent": "reviewer",
      "template": "Review the current git diff without editing files. Check correctness, temporal pickup/putdown semantics, frame-to-timestamp conversions, ffmpeg/ffprobe command construction, schema compatibility, storage/cache behavior, typing, deterministic tests, and regression risk. Report findings in severity order."
    },
    "plan-change": {
      "description": "Plan a repository change without editing",
      "agent": "plan",
      "template": "Inspect the relevant repository files and AGENTS.md, then propose the smallest implementation plan that satisfies the request. Identify affected modules, tests, assumptions, and validation commands. Do not edit files."
    },
    "work-task": {
      "description": "Work from a repository task specification",
      "agent": "build",
      "template": "Read the task specification at $ARGUMENTS together with AGENTS.md and any documents it explicitly requires. Inspect the current implementation, execute the task with minimal targeted changes, run the relevant verification targets, and summarize changed files, tests, and unresolved risks."
    }
